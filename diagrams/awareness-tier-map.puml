@startuml
!theme plain
title Project Coherent Storage - Rapid Awareness Audience Tiers
left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName DejaVu Sans
skinparam packageStyle rectangle

rectangle "Executive Summary" as Exec #D6EAF8 {
  [Why CXL matters]
  [Why DPUs are required]
  [Business value and risk]
  [Evidence-grade roadmap claims]
}
rectangle "Director Review" as Dir #D5F5E3 {
  [Procurement matrix]
  [Topology and lifecycle]
  [Operational readiness]
  [Risk register]
}
rectangle "Technical Engineering / ARB" as ARB #FCF3CF {
  [Coherence-CE data path]
  [CXL/OpenZFS role matrix]
  [DPU/RDMA/NVMe-oF qualification]
  [Failure and scheduler gates]
}
rectangle "Research / Publication" as Pub #FADBD8 {
  [arXiv metadata APIs]
  [RAG manifests]
  [LaTeX + BibTeX]
  [Claim guardrails]
}

Exec --> Dir : funding / roadmap questions
Dir --> ARB : design constraints
ARB --> Pub : source-backed claims
Pub --> Exec : safe summaries
@enduml
