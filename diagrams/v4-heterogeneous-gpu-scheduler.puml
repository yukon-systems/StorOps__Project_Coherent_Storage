@startuml
!theme plain
title v4 Heterogeneous GP-GPU Scheduler Capability Profiles
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName DejaVu Sans
left to right direction

rectangle "Capability Profile" as P #D6EAF8 {
  [Vendor/runtime]
  [HBM capacity/bandwidth]
  [Precision/compiler]
  [Collectives]
  [RDMA memory semantics]
  [UA-Link/NVLink/domain]
  [CXL reachability]
  [DPU/NIC affinity]
}
component "Workload request\nmodel + KV class + SLO" as W #FCF3CF
component "Scheduler" as S #D5F5E3
component "Coherence-CE" as CE #E8DAEF
component "NVIDIA / AMD / Intel\nGPU pools" as G #FADBD8

W --> S
P --> S
S --> G : eligible placement
S --> CE : placement + admission
CE --> S : TTFT/TPOT/KV/fabric metrics
@enduml
